{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "dbase",
  "scopeName": "source.dbase",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#classes" },
    { "include": "#functions" },
    { "include": "#properties" },
    { "include": "#variables" },
    { "include": "#operators" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dbase",
          "match": "//.*$"
        },
        {
          "name": "comment.line.asterisk.dbase",
          "match": "\\*\\*.*$"
        }
      ]
    },

    "strings": {
	  "patterns": [
	    {
	      "name": "string.quoted.double.sql.dbase",
	      "begin": "\"(?=(SELECT|INSERT|UPDATE|DELETE|CREATE|DROP)\\b)",
	      "beginCaptures": {
	        "0": { "name": "punctuation.definition.string.begin.dbase" }
	      },
	      "end": "\"",
	      "endCaptures": {
	        "0": { "name": "punctuation.definition.string.end.dbase" }
	      },
	      "patterns": [
	        {
	          "include": "source.sql"
	        }
	      ]
	    },
	    {
	      "name": "string.quoted.double.dbase",
	      "begin": "\"",
	      "end": "\""
	    },
	    {
	      "name": "string.quoted.single.dbase",
	      "begin": "'",
	      "end": "'"
	    }
	  ]
	},

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dbase",
          "match": "\\b(IF|ELSE|ENDIF|RETURN|WITH|ENDWITH)\\b"
        },
        {
          "name": "storage.type.dbase",
          "match": "\\b(CLASS|FUNCTION|PARAMETER|LOCAL)\\b"
        },
        {
          "name": "keyword.other.new.dbase",
          "match": "\\b(NEW)\\b"
        }
      ]
    },

    "classes": {
      "patterns": [
        {
          "name": "entity.name.type.class.dbase",
          "match": "\\b[Cc][Ll][Aa][Ss][Ss]\\s+([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.dbase",
          "match": "\\b[Ff][Uu][Nn][Cc][Tt][Ii][Oo][Nn]\\s+([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },

    "properties": {
      "patterns": [
        {
          "name": "variable.other.property.dbase",
          "match": "\\.[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "name": "variable.language.this.dbase",
          "match": "\\b(this|form)\\b"
        },
        {
          "name": "variable.other.dbase",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.dbase",
          "match": "\\.(AND|OR|NOT)\\."
        },
        {
          "name": "keyword.operator.assignment.dbase",
          "match": "="
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.dbase",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    }
  }
}