{
  "name": "dbase-support",
  "displayName": "dBase Support",
  "publisher": "Icesito68",
  "description": "test project to provide basic support to dbase",
  "version": "0.0.2",
  "author": "Icesito68",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Icesito68/dbase-extension.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "dbase",
      "aliases": ["dbase", "dbase"],
      "extensions": [".wfm","cfm","prj"],
      "configuration": "./language-configuration.json",
      "defaultEncoding": "windows1252"
    }],
    "grammars": [{
      "language": "dbase",
      "scopeName": "source.dbase",
      "path": "./syntaxes/dbase.tmLanguage.json"
    }]
  }
}
