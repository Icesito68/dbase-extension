{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "dBASE",
  "scopeName": "source.dbase",
  "fileTypes": ["prg", "rep", "frm", "wfm", "pop", "men", "dbo", "cc", "h"],
  "patterns": [
    { "include": "#preprocessor" },
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#logical-constants" },
    { "include": "#keywords-control" },
    { "include": "#keywords-commands" },
    { "include": "#storage-types" },
    { "include": "#keyword-operators" },
    { "include": "#exception-handling" },
    { "include": "#class-definition" },
    { "include": "#function-definition" },
    { "include": "#builtin-functions" },
    { "include": "#builtin-classes" },
    { "include": "#variables-special" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#properties" },
    { "include": "#function-call" },
    { "include": "#variables" }
  ],
  "repository": {

    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.dbase",
          "match": "(?i)^\\s*(#(?:define|undef|ifdef|ifndef|else|endif|include))\\b(.*)$",
          "captures": {
            "1": { "name": "keyword.control.directive.dbase" },
            "2": { "name": "string.unquoted.preprocessor.dbase" }
          }
        },
        {
          "name": "meta.preprocessor.define.dbase",
          "match": "(?i)^\\s*(#define)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(.*)",
          "captures": {
            "1": { "name": "keyword.control.directive.dbase" },
            "2": { "name": "entity.name.constant.dbase" },
            "3": { "name": "string.unquoted.preprocessor.dbase" }
          }
        }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.dbase",
          "match": "//.*$"
        },
        {
          "name": "comment.line.asterisk.dbase",
          "match": "^\\s*\\*\\*.*$"
        },
        {
          "name": "comment.line.note.dbase",
          "match": "(?i)^\\s*(NOTE|&&).*$",
          "captures": {
            "1": { "name": "comment.keyword.dbase" }
          }
        },
        {
          "name": "comment.block.dbase",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "name": "comment.block.documentation.tag.dbase",
              "match": "@(?:param|return|author|version|since|see|throws|todo)\\b"
            }
          ]
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "comment": "Double-quoted string containing embedded SQL",
          "name": "string.quoted.double.sql.dbase",
          "begin": "\"(?=\\s*(?:SELECT|INSERT|UPDATE|DELETE|CREATE|DROP|ALTER|TRUNCATE|EXEC|EXECUTE|BEGIN|COMMIT|ROLLBACK|GRANT|REVOKE)\\b)",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.dbase" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.dbase" }
          },
          "patterns": [
            { "include": "source.sql" }
          ]
        },
        {
          "comment": "Double-quoted string with escape sequences",
          "name": "string.quoted.double.dbase",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.dbase" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.dbase" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dbase",
              "match": "\\\\(?:[nrtbf\\\\\"']|[0-7]{3}|x[0-9A-Fa-f]{2})"
            }
          ]
        },
        {
          "comment": "Single-quoted string with escape sequences",
          "name": "string.quoted.single.dbase",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.dbase" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.dbase" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dbase",
              "match": "\\\\(?:[nrtbf\\\\\"']|[0-7]{3}|x[0-9A-Fa-f]{2})"
            }
          ]
        },
        {
          "comment": "Bracket-quoted string (dBase 11 style)",
          "name": "string.quoted.other.bracket.dbase",
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.dbase" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.dbase" }
          }
        }
      ]
    },

    "logical-constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.dbase",
          "match": "(?i)\\.(T|F|TRUE|FALSE)\\."
        },
        {
          "name": "constant.language.null.dbase",
          "match": "(?i)\\b(NULL|NIL)\\b"
        },
        {
          "name": "constant.language.undefined.dbase",
          "match": "(?i)\\b(UNDEFINED)\\b"
        }
      ]
    },

    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.conditional.dbase",
          "match": "(?i)\\b(IF|ELSE|ELSEIF|ENDIF|IIF|ICASE)\\b"
        },
        {
          "name": "keyword.control.loop.dbase",
          "match": "(?i)\\b(FOR|FOREACH|ENDFOR|DO|WHILE|ENDWHILE|LOOP|EXIT|NEXT|IN|TO|STEP|SCAN|ENDSCAN)\\b"
        },
        {
          "name": "keyword.control.flow.dbase",
          "match": "(?i)\\b(RETURN|QUIT|CANCEL|SUSPEND|RESUME)\\b"
        },
        {
          "name": "keyword.control.object.dbase",
          "match": "(?i)\\b(WITH|ENDWITH)\\b"
        },
        {
          "name": "keyword.control.switch.dbase",
          "match": "(?i)\\b(DO\\s+CASE|CASE|OTHERWISE|ENDCASE)\\b"
        }
      ]
    },

    "exception-handling": {
      "patterns": [
        {
          "name": "keyword.control.exception.dbase",
          "match": "(?i)\\b(TRY|CATCH|FINALLY|ENDTRY|THROW|ON\\s+ERROR)\\b"
        }
      ]
    },

    "keywords-commands": {
      "patterns": [
        {
          "name": "keyword.other.command.dbase",
          "match": "(?i)^\\s*(ACCEPT|APPEND|AVERAGE|BROWSE|CALCULATE|CALL|CHANGE|CLEAR|CLOSE|COMPILE|CONTINUE|COPY|COUNT|CREATE|DELETE|DISPLAY|EDIT|ERASE|EXPORT|FIND|GO|GOTO|IMPORT|INDEX|INPUT|JOIN|KEYBOARD|LIST|LOAD|LOCATE|MODIFY|MOVE|OPEN|PACK|PRINT|RECALL|REINDEX|RELEASE|RENAME|REPLACE|REPORT|RESTORE|RUN|SAVE|SEEK|SELECT|SET|SKIP|SORT|STORE|SUM|TOTAL|TYPE|UNLOAD|UPDATE|USE|WAIT|ZAP)\\b"
        },
        {
          "name": "keyword.other.set.dbase",
          "match": "(?i)\\b(SET)\\s+(CENTURY|COLOR|CONFIRM|CONSOLE|DATE|DECIMALS|DEFAULT|DELETED|ECHO|ESCAPE|EXACT|EXCLUSIVE|FILTER|FORMAT|HEADING|HELP|INDEX|INTENSITY|LIBRARY|MARGIN|MEMOWIDTH|MESSAGE|ORDER|PATH|PRINT|PROCEDURE|RELATION|REPROCESS|SAFETY|SCOREBOARD|STATUS|STEP|TALK|TITLE|TO|TYPEAHEAD|UNIQUE|VIEW)\\b"
        }
      ]
    },

    "storage-types": {
      "patterns": [
        {
          "name": "storage.type.dbase",
          "match": "(?i)\\b(CLASS|FUNCTION|PROCEDURE|PARAMETER|PARAMETERS|LOCAL|PRIVATE|PUBLIC|STATIC|PROTECTED|VIRTUAL|ABSTRACT|OVERRIDE|READONLY|EXTERN)\\b"
        },
        {
          "name": "storage.modifier.access.dbase",
          "match": "(?i)\\b(NEW|DELETE|RELEASE)\\b"
        },
        {
          "name": "storage.type.declare.dbase",
          "match": "(?i)\\b(DECLARE|DIMENSION|ARRAY)\\b"
        }
      ]
    },

    "keyword-operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.dbase",
          "match": "(?i)\\.(AND|OR|NOT|XOR)\\."
        },
        {
          "name": "keyword.operator.word.dbase",
          "match": "(?i)\\b(AND|OR|NOT|IN|LIKE|BETWEEN|IS|AS|INSTANCEOF|TYPEOF)\\b"
        }
      ]
    },

    "class-definition": {
      "patterns": [
        {
          "name": "meta.class.dbase",
          "match": "(?i)\\b(CLASS)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(OF|EXTENDS)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "storage.type.class.dbase" },
            "2": { "name": "entity.name.type.class.dbase" },
            "3": { "name": "storage.modifier.extends.dbase" },
            "4": { "name": "entity.other.inherited-class.dbase" }
          }
        },
        {
          "name": "keyword.other.class.dbase",
          "match": "(?i)\\b(ENDCLASS|ENDFUNC|ENDPROC|ENDPROCEDURE)\\b"
        }
      ]
    },

    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.dbase",
          "match": "(?i)\\b(FUNCTION|PROCEDURE)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.dbase" },
            "2": { "name": "entity.name.function.dbase" }
          }
        }
      ]
    },

    "builtin-functions": {
      "patterns": [
        {
          "comment": "String functions",
          "name": "support.function.string.dbase",
          "match": "(?i)\\b(ALLTRIM|AT|ATC|CHR|LEFT|LEN|LOWER|LTRIM|OCCURS|PAD|PADL|PADR|PADC|PROPER|REPLICATE|RIGHT|RTRIM|SPACE|STR|STRTRAN|STUFF|SUBSTR|TRANSFORM|TRIM|UPPER|VAL|ASC|AATSTR|ATCLINE|ATLINE|CHRTRAN|DIFFERENCE|LIKE|SOUNDEX|SUBS|WORDCOUNT|WORDNUM)(?=\\s*\\()"
        },
        {
          "comment": "Numeric functions",
          "name": "support.function.numeric.dbase",
          "match": "(?i)\\b(ABS|CEILING|EXP|FLOOR|INT|LOG|LOG10|MAX|MIN|MOD|PI|RAND|ROUND|SIGN|SQRT|DTOR|RTOD|COS|SIN|TAN|ACOS|ASIN|ATAN|ATAN2)(?=\\s*\\()"
        },
        {
          "comment": "Date and time functions",
          "name": "support.function.datetime.dbase",
          "match": "(?i)\\b(CDOW|CMONTH|CTOD|DATE|DAY|DATETIME|DMY|DOW|DTOC|DTOS|ELAPSED|GOMONTH|MDY|MONTH|MTON|NTOM|SECONDS|STOD|STOT|TIME|TTOS|YEAR|HOUR|MINUTE|SECOND|DTOT|TTOD|DTOTIME|TIMETODT)(?=\\s*\\()"
        },
        {
          "comment": "Type testing and conversion functions",
          "name": "support.function.type.dbase",
          "match": "(?i)\\b(TYPE|VALTYPE|EMPTY|ISALPHA|ISDIGIT|ISLOWER|ISUPPER|ISBLANK|ISNULL|ISLEAPYEAR|ISREADONLY|ISARRAY|ISOBJECT|VARTYPE|TYPEOF|INSTANCEOF)(?=\\s*\\()"
        },
        {
          "comment": "Array functions",
          "name": "support.function.array.dbase",
          "match": "(?i)\\b(ACOPY|ADEL|ADIR|AELEMENT|AFIELDS|AFILL|AINS|ALEN|ARRAY|ASCAN|ASORT|ASUBSCRIPT|AAVERAGEA|AMAXARRAY|AMINARRAY|ASUMARRAY)(?=\\s*\\()"
        },
        {
          "comment": "Database functions",
          "name": "support.function.database.dbase",
          "match": "(?i)\\b(ALIAS|BOF|DELETED|EOF|FCOUNT|FIELD|FIELDNAME|FIELDNO|FIELDTYPE|FIELDSIZE|FILTER|FOUND|HEADER|LASTREC|LOOKUP|ORDER|RECCOUNT|RECNO|RECSIZE|RELATION|SELECT|SEEK|TAGCOUNT|TAGNAME|TAGNO|TARGET|USED|DBSEEK|DBRLOCK|DBRUNLOCK|DBREINDEX|DBCOMMIT|DBROLLBACK|DBTRANSACTION)(?=\\s*\\()"
        },
        {
          "comment": "File and I/O functions",
          "name": "support.function.file.dbase",
          "match": "(?i)\\b(FCLOSE|FCREATE|FEOF|FERROR|FFLUSH|FGET|FGETS|FOPEN|FPUTS|FREAD|FSEEK|FTELL|FWRITE|FILE|FILEDATE|FILESIZE|FILETIME|DISKSPACE|DIRECTORY|FCHSIZE|FGETPOS|FSETPOS|LOWFILEDATE|LOWFILETIME|LOWFILESIZE|ADIR)(?=\\s*\\()"
        },
        {
          "comment": "Object and UI functions",
          "name": "support.function.object.dbase",
          "match": "(?i)\\b(CREATEOBJECT|GETOBJECT|RELEASE|LOADOBJECT|SAVEOBJECT|OBJECTS|OBJECTCOUNT|ACLASSES|AMEMBERS|COMPOBJ|COPYTAG|MACROFUNC|EVALUATE|EXECSCRIPT)(?=\\s*\\()"
        },
        {
          "comment": "System functions",
          "name": "support.function.system.dbase",
          "match": "(?i)\\b(GETENV|GETREGISTRY|SETREGISTRY|OS|VERSION|MEMORY|DISKSPACE|ISMOUSE|ISCOLOR|ISALPHA|COMSPEC|PCOUNT|PARAMETERS|VARREAD|READKEY|INKEY|KEYBOARD|KEYMATCH|ISKEY|MODIFIED|UPDATED|ROWCOUNT|COLCOUNT|ROW|COL|MAXROW|MAXCOL|SROW|SCOL|SMAXROW|SMAXCOL)(?=\\s*\\()"
        },
        {
          "comment": "Error handling functions",
          "name": "support.function.error.dbase",
          "match": "(?i)\\b(ERROR|MESSAGE|LINENO|PROGRAM|PROCNAME|PROCKCOUNT|ASTACK|ONERROR|LASTERROR|CERROR|CERRORLINE)(?=\\s*\\()"
        },
        {
          "comment": "Cryptography and encoding",
          "name": "support.function.crypto.dbase",
          "match": "(?i)\\b(ENCRYPTB64|DECRYPTB64|ENCRYPTAES|DECRYPTAES|MD5|SHA1|SHA256|CRYPT|DECRYPT|HEXENCODE|HEXDECODE)(?=\\s*\\()"
        },
        {
          "comment": "Network and internet",
          "name": "support.function.network.dbase",
          "match": "(?i)\\b(SENDMAIL|GETURL|POSTURL|URLENCODE|URLDECODE|HTMLENCODE|HTMLDECODE|XMLENCODE|XMLDECODE|JSONENCODE|JSONDECODE|BASE64ENCODE|BASE64DECODE)(?=\\s*\\()"
        }
      ]
    },

    "builtin-classes": {
      "patterns": [
        {
          "comment": "Core dBase 11 built-in classes",
          "name": "support.class.dbase",
          "match": "(?i)\\b(Array|AssocArray|BinaryString|Boolean|Currency|Date|DateTime|Exception|File|Form|Grid|Image|Integer|List|Memo|Numeric|Object|OLEControl|Query|Report|ResultSet|Session|Sound|StreamReader|StreamWriter|String|TextLabel|Timer|WebSession|XML|XMLDocument|XMLElement|XMLNode|XSL)(?=\\s*[:(\\s]|$)"
        },
        {
          "comment": "UI components",
          "name": "support.class.ui.dbase",
          "match": "(?i)\\b(Button|CheckBox|ComboBox|Container|DataModuleForm|DBEdit|DBGrid|DBNavigator|DBText|Editor|Entryfield|Form|HtmlControl|Image|Label|Line|ListBox|MDIChild|MDIForm|Memo|Menu|MenuItem|Notebook|Page|Panel|Popup|PrinterSetup|PushButton|RadioButton|Rectangle|Rectangle|ScrollBar|Shape|SpeedBar|SpinBox|StatusBar|SubForm|TabBox|TextLabel|Timer|ToolBar|TreeView|WebBrowser|Window)(?=\\s*[:(\\s]|$)"
        },
        {
          "comment": "Data access classes",
          "name": "support.class.data.dbase",
          "match": "(?i)\\b(DataSource|DbfQuery|Field|Index|Query|QueryBuilder|Relation|ResultSet|RowSet|Session|SqlQuery|StoredProc|Table|UpdateSet)(?=\\s*[:(\\s]|$)"
        }
      ]
    },

    "variables-special": {
      "patterns": [
        {
          "name": "variable.language.dbase",
          "match": "(?i)\\b(this|form|_app|_dbaseWin|_screen|_tally|_server|_pageno|_plineno|_ploffset|_pbpage|_pepage|_box|_indent|_lmargin|_rmargin|_pspacing|_peject|_ppitch|_pquality|_padvance|_wrap|_nativecode|_windows|_dos|_mac|_unix|_shell|_dbase|_dbwith|_browseCode|_browseObject)\\b"
        },
        {
          "name": "variable.language.scope.dbase",
          "match": "(?i)\\b(m->|M->)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.scope.dbase" },
            "2": { "name": "variable.other.memory.dbase" }
          }
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.dbase",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.scientific.dbase",
          "match": "\\b\\d+(\\.\\d+)?[eE][+-]?\\d+\\b"
        },
        {
          "name": "constant.numeric.float.dbase",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.dbase",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.dbase",
          "match": "(==|!=|<>|<=|>=|<|>|=)"
        },
        {
          "name": "keyword.operator.arithmetic.dbase",
          "match": "(\\+\\+|--|\\+=|-=|\\*=|/=|\\*\\*|\\^|\\*|/|%|\\+|-)"
        },
        {
          "name": "keyword.operator.string.dbase",
          "match": "(\\$|\\-)"
        },
        {
          "name": "keyword.operator.bitwise.dbase",
          "match": "(&|\\||~|<<|>>)"
        },
        {
          "name": "punctuation.separator.dbase",
          "match": "(,|;|:)"
        },
        {
          "name": "punctuation.terminator.dbase",
          "match": "\\."
        }
      ]
    },

    "properties": {
      "patterns": [
        {
          "name": "meta.property.access.dbase",
          "match": "(::[A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.property.inherited.dbase" }
          }
        },
        {
          "name": "variable.other.property.dbase",
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.member.dbase" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.dbase",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.dbase" }
          }
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "name": "variable.other.dbase",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b"
        }
      ]
    }
  }
}